#!/usr/bin/env bash
# SessionStart hook for cospec plugin
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Verification marker: cross-platform log (works on Windows Git Bash, macOS, Linux)
printf '%s session-start called from %s\n' "$(date -Iseconds 2>/dev/null || date +%Y-%m-%dT%H:%M:%S%z)" "$0" >> "${PLUGIN_ROOT}/.session-start.log" 2>/dev/null || true

# # Always refresh kb-Product knowledge base to latest (non-blocking, stderr only)
# KB_QUERY_TARGET="${HOME}/.claude/skills/kb-query"
# if [ -d "${KB_QUERY_TARGET}" ]; then
#   # Already exists: always attempt git pull, fall back to setup-deps on failure
#   git -C "${KB_QUERY_TARGET}" pull --ff-only >/dev/null 2>/dev/null || \
#     bash "${PLUGIN_ROOT}/scripts/setup-deps.sh" 2>/dev/null || true
# else
#   # Not installed: clone fresh
#   bash "${PLUGIN_ROOT}/scripts/setup-deps.sh" 2>/dev/null || true
# fi

# cospec activation hint (bounded). The full skill-discipline guide that used
# to be injected here (using-spec-developer) has been moved to
# docs/using-spec-developer/ and is no longer force-injected into every session,
# because it over-broadened skill triggering (see skill-trigger-false-positive-analysis.md).
session_context="<system-reminder>\ncospec 已安装。仅当用户明确要求“使用 cospec”或继续已启动的 cospec 工作流时，才调用 brainstorming 入口。\n仅提及、讨论、分析、修复或优化 cospec 本身，或总结／筛选包含 cospec 关键词的文件，均不触发 cospec 工作流。\n用户明确表示“不要使用 cospec”时，当前任务内禁止任何 cospec Skill。\n</system-reminder>"

memory_hint=""
if [ -d "memory" ]; then
  recent_mem=$(ls -t memory/*.md 2>/dev/null | head -2 | while read -r f; do
    basename "$f" .md
  done | tr '\n' ',' | sed 's/,$//') || true
  if [ -n "$recent_mem" ]; then
    memory_hint="\\n🧠 **项目经验索引:** ${recent_mem}\\n做相关决策时查阅 memory/ 对应文件。"
  fi
fi

session_context="${session_context}${memory_hint}"

# Output context injection as JSON
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
