# Ensure shell scripts always have LF line endings
*.sh text eol=lf
plugins/cospec/hooks/session-start text eol=lf
plugins/cospec/hooks/usage-report text eol=lf
plugins/cospec/hooks/skill-usage-report text eol=lf

# Common text files
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.gif binary
